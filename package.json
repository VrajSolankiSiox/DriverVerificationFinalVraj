{
    "name":  "hotel-demo-intelligence",
    "version":  "1.0.0",
    "private":  true,
    "engines":  {
                    "node":  "\u003e=20.10.0"
                },
    "scripts":  {
                    "dev":  "next dev",
                    "build":  "next build",
                    "vercel-build":  "prisma generate \u0026\u0026 node scripts/normalize-legacy-roles.mjs \u0026\u0026 prisma db push --accept-data-loss \u0026\u0026 prisma db seed \u0026\u0026 next build",
                    "start":  "next start",
                    "lint":  "eslint . --ext .ts,.tsx",
                    "typecheck":  "tsc --noEmit",
                    "format":  "prettier --write .",
                    "prisma:generate":  "prisma generate",
                    "prisma:migrate":  "echo \"Migrations removed. Use npm run prisma:push\"",
                    "prisma:migrate:local":  "echo \"Migrations removed. Use npm run prisma:push:local\"",
                    "prisma:deploy:local":  "echo \"Migrations removed. Use npm run prisma:push:local\"",
                    "prisma:push":  "prisma db push",
                    "prisma:push:local":  "node scripts/prisma-local.mjs db push",
                    "prisma:seed":  "tsx --env-file=.env prisma/seed.ts",
                    "prisma:seed:local":  "tsx --env-file=.env.local prisma/seed.ts",
                    "test":  "vitest run",
                    "test:watch":  "vitest",
                    "test:e2e":  "playwright test",
                    "postinstall":  "prisma generate"
                },
    "dependencies":  {
                         "@hookform/resolvers":  "^3.9.0",
                         "@prisma/client":  "^6.19.2",
                         "@tanstack/react-table":  "^8.20.5",
                         "bcryptjs":  "^2.4.3",
                         "cheerio":  "^1.1.2",
                         "clsx":  "^2.1.1",
                         "date-fns":  "^4.1.0",
                         "dotenv":  "^17.3.1",
                         "lucide-react":  "^0.469.0",
                         "next":  "^16.2.2",
                         "next-auth":  "^4.24.11",
                         "pptxgenjs":  "^4.0.1",
                         "react":  "19.0.0",
                         "react-dom":  "19.0.0",
                         "react-hook-form":  "^7.53.0",
                         "react-toastify":  "^11.0.5",
                         "recharts":  "^3.1.2",
                         "tailwind-merge":  "^2.5.2",
                         "xlsx":  "^0.18.5",
                         "zod":  "^3.23.8"
                     },
    "devDependencies":  {
                            "@playwright/test":  "^1.55.0",
                            "@types/node":  "^22.10.0",
                            "@types/react":  "^19.0.2",
                            "@types/react-dom":  "^19.0.2",
                            "autoprefixer":  "^10.4.20",
                            "eslint":  "^8.57.1",
                            "eslint-config-next":  "15.5.0",
                            "postcss":  "^8.4.49",
                            "prettier":  "^3.4.2",
                            "prisma":  "^6.16.2",
                            "tailwindcss":  "^3.4.17",
                            "tsx":  "^4.19.2",
                            "typescript":  "^5.9.3",
                            "vitest":  "^2.1.5"
                        },
    "prisma":  {
                   "seed":  "tsx prisma/seed.ts"
               }
}

